{
  "name": "trainforge-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev -c wrangler.dev.toml --port 2020",
    "build": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "deploy:production": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "load-test": "node scripts/load-test.mjs",
    "db:migrate:local": "wrangler d1 migrations apply trainforge-db --local -c wrangler.dev.toml",
    "db:migrate:remote": "wrangler d1 migrations apply trainforge-db --remote -c wrangler.production.toml",
    "exrx:discover": "node scripts/scrape-exrx.mjs discover",
    "exrx:scrape": "node scripts/scrape-exrx.mjs scrape --resume",
    "exrx:import": "node scripts/import-exrx-to-d1.mjs",
    "exercises:import": "node scripts/import-exercisedb.mjs",
    "exercises:import:remote": "node scripts/import-exercisedb.mjs --remote --from-cache",
    "exercises:remove-invalid": "node scripts/remove-invalid-exercises.mjs",
    "exercises:remove-invalid:remote": "node scripts/remove-invalid-exercises.mjs --remote",
    "exercises:backfill-filters": "node scripts/backfill-exercise-filters.mjs",
    "exercises:backfill-filters:remote": "node scripts/backfill-exercise-filters.mjs --remote"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.3",
    "hono": "^4.7.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.14",
    "@cloudflare/workers-types": "^4.20250317.0",
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "playwright": "^1.61.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.8",
    "wrangler": "^4.6.0"
  }
}
